rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write only their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to read/write fire_status and commands
    match /fire_status/{document} {
      allow read, write: if true;
    }
    match /commands/{document} {
      allow read, write: if true;
    }

    // Deny all other collections/documents by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

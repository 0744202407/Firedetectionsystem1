<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="#221212"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="#332222"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgAlertIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_dialog_alert"
            app:tint="@color/fire_red_primary"
            android:padding="8dp"
            android:background="#1A1A1A" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtAlertStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FIRE DETECTED"
                android:textColor="#FF4444"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtAlertTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="2023-10-01 14:30"
                android:textColor="#BBBBBB"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtAlertDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Loc: Station 1 | Smoke: 85%"
                android:textColor="#888888"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a0f0f"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/real_time_alerts"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"/>

    <ImageView
        android:id="@+id/imgStatusIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="20dp"
        android:src="@android:drawable/ic_dialog_info"
        app:tint="#00ff00" />

    <TextView
        android:id="@+id/tvFullStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="NO FIRE DETECTED"
        android:textColor="#00ff00"
        android:textSize="28sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="30dp"
        android:background="#33ffffff" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="start">

        <TextView
            android:id="@+id/tvFullSmokeLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Smoke level: 0"
            android:textColor="#BBBBBB"
            android:textSize="18sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="30dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:backgroundTint="#FF4444"
            android:text="@string/close"
            android:textColor="#FFFFFF" />

        <ImageButton
            android:id="@+id/btnVoiceAlert"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="@drawable/dashboard_icon_emergency_btn"
            android:contentDescription="Voice Command"
            app:tint="#FFFFFF"
            android:padding="12dp"
            android:scaleType="centerInside"/>
    </LinearLayout>

</LinearLayout>

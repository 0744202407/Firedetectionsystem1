<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a0f0f">

    <!-- Title -->
    <TextView
        android:text="@string/register_account"
        android:textSize="26sp"
        android:textColor="#ffffff"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Username / Email -->
    <EditText
        android:id="@+id/etUsername"
        android:hint="@string/enter_username_email"
        android:textColor="#ffffff"
        android:textColorHint="#aaaaaa"
        android:textSize="16sp"
        android:background="@drawable/input_bg"
        android:padding="14dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textEmailAddress"/>

    <!-- Phone Number -->
    <EditText
        android:id="@+id/etPhone"
        android:hint="Phone Number (e.g. +255...)"
        android:textColor="#ffffff"
        android:textColorHint="#aaaaaa"
        android:textSize="16sp"
        android:background="@drawable/input_bg"
        android:padding="14dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:inputType="phone"/>

    <!-- Password + Visibility -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:background="@drawable/input_bg"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="@string/enter_password"
            android:inputType="textPassword"
            android:paddingEnd="8dp"
            android:textColor="#ffffff"
            android:textColorHint="#aaaaaa"
            android:textSize="16sp" />

        <ImageButton
            android:id="@+id/toggleRegisterPasswordBtn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/visibility_off"
            android:src="@drawable/ic_visibility_off" />
    </LinearLayout>

    <!-- Register Button Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="@string/register"
            android:textColor="#ffffff"
            android:background="@drawable/login_btn_bg"
            app:backgroundTint="@null"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:textStyle="bold"
            android:textSize="18sp"/>

        <ImageButton
            android:id="@+id/btnVoiceRegister"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginStart="12dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="@drawable/dashboard_icon_btn"
            android:contentDescription="@string/voice_command"
            app:tint="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>
